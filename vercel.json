{
  "version": 2,
  "builds": [
    { "src": "dist/client/**/*.js", "use": "@vercel/static" },
    { "src": "dist/client/**/*.css", "use": "@vercel/static" },
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/dist/client/assets/$1",
      "headers": {
        "Content-Type": "application/javascript"
      }
    },
    {
      "src": "/assets/(.*)",
      "dest": "/dist/client/assets/$1",
      "headers": {
        "Content-Type": "text/css"
      }
    },
    { "src": "/(.*)", "dest": "server.js" }
  ]
}
